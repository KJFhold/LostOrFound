{
  "expo": {
    "name": "Lost or Found",
    "slug": "RepairLostOrFound",
    "icon": "./assets/images/icon.png",
    "scheme": "lostorfound",
    "extra": {
      "eas": {
        "projectId": "42c24037-c853-47ae-bb4c-5208947e1270"
      }
    },
    "android": {
      "package": "com.kjfok.lostorfound",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "backgroundColor": "#CFE9FF"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "categories": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "lostorfound"
            }
          ]
        }
      ],
      "permissions": [
        "ACCESS_FINE_LOCATION"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "REPLACE_WITH_ANDROID_GOOGLE_MAPS_API_KEY_IF_BUILDING_ANDROID"
        }
      }
    },
    "ios": {
      "bundleIdentifier": "com.kjfok.lostorfound",
      "icon": "./assets/images/icon.png",
      "associatedDomains": [],
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "lostorfound"
            ]
          }
        ],
        "NSLocationWhenInUseUsageDescription": "Vi bruker posisjonen din for å vise treff i nærheten på kartet.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.kjfok.lostorfound",
          "enableGooglePay": true
        }
      ],
      "expo-localization",
      "expo-font",
      "react-native-localize"
    ]
  }
}
