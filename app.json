{
  "expo": {
    "name": "Lost or Found",
    "slug": "RepairLostOrFound",
    "icon": "./assets/images/icon.png",
    "scheme": "lostorfound",
    "android": {
      "package": "com.anonymous.RepairLostOrFound",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png",
        "backgroundColor": "#CFE9FF"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": false,
          "categories": ["BROWSABLE", "DEFAULT"],
          "data": [{ "scheme": "lostorfound" }]
        }
      ],
      "permissions": ["ACCESS_FINE_LOCATION"],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCbpbjPsvPbOShMqq2JyhvXcPx90Ul5TSc"
        }
      }
    },
    "ios": {
      "bundleIdentifier": "com.anonymous.RepairLostOrFound",
      "icon": "./assets/images/icon.png",
      "associatedDomains": [],
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["lostorfound"]
          }
        ],
        "NSLocationWhenInUseUsageDescription": "Vi bruker posisjonen din for å vise treff i nærheten på kartet."
      }
    },
    "plugins": [
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.anonymous.repairlostorfound",
          "enableGooglePay": true
        }
      ]
    ]
  }
}